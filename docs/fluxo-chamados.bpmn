<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="defs_fluxo_chamados" targetNamespace="http://cpii.seng/chamados" exporter="cpii-seng" exporterVersion="1.13.2">
<bpmn:collaboration id="colab1"><bpmn:participant id="pool1" name="SENG Demandas — Tratamento de chamados (Portaria 7503/2025)" processRef="proc1"/></bpmn:collaboration>
<bpmn:process id="proc1" isExecutable="false">
<bpmn:laneSet id="ls1">
<bpmn:lane id="lane_campus" name="Campus (solicitante)"><bpmn:flowNodeRef>se1</bpmn:flowNodeRef><bpmn:flowNodeRef>t_abrir</bpmn:flowNodeRef><bpmn:flowNodeRef>t_resp</bpmn:flowNodeRef></bpmn:lane>
<bpmn:lane id="lane_seng" name="SENG / DECOF"><bpmn:flowNodeRef>t_triar</bpmn:flowNodeRef><bpmn:flowNodeRef>g1</bpmn:flowNodeRef><bpmn:flowNodeRef>t_dilig</bpmn:flowNodeRef><bpmn:flowNodeRef>g2</bpmn:flowNodeRef><bpmn:flowNodeRef>t_conv</bpmn:flowNodeRef><bpmn:flowNodeRef>call1</bpmn:flowNodeRef><bpmn:flowNodeRef>ee_obra</bpmn:flowNodeRef><bpmn:flowNodeRef>t_aloc</bpmn:flowNodeRef><bpmn:flowNodeRef>t_atend</bpmn:flowNodeRef><bpmn:flowNodeRef>t_nt</bpmn:flowNodeRef><bpmn:flowNodeRef>ee_res</bpmn:flowNodeRef><bpmn:flowNodeRef>t_enc</bpmn:flowNodeRef><bpmn:flowNodeRef>ee_enc</bpmn:flowNodeRef><bpmn:flowNodeRef>ee_ne</bpmn:flowNodeRef></bpmn:lane>
</bpmn:laneSet>
<bpmn:startEvent id="se1" name="Necessidade identificada"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
<bpmn:userTask id="t_abrir" name="Abrir chamado&#10;(categoria, urgência, local,&#10;descrição, anexos)"><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing></bpmn:userTask>
<bpmn:userTask id="t_resp" name="Responder diligência&#10;(complementa e devolve)"><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing></bpmn:userTask>
<bpmn:userTask id="t_triar" name="Triar chamado&#10;(análise da solicitação)"><bpmn:incoming>f2</bpmn:incoming><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing></bpmn:userTask>
<bpmn:exclusiveGateway id="g1" name="Precisa de&#10;complemento?"><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing><bpmn:outgoing>f7</bpmn:outgoing></bpmn:exclusiveGateway>
<bpmn:userTask id="t_dilig" name="Solicitar diligência&#10;(SLA pausa)"><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
<bpmn:exclusiveGateway id="g2" name="Desfecho da&#10;triagem?"><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing><bpmn:outgoing>f11</bpmn:outgoing><bpmn:outgoing>f15</bpmn:outgoing><bpmn:outgoing>f17</bpmn:outgoing></bpmn:exclusiveGateway>
<bpmn:userTask id="t_conv" name="Classificar e converter&#10;em demanda de obra"><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing></bpmn:userTask>
<bpmn:callActivity id="call1" name="Fluxo de demandas&#10;(GUT, CODIR, fila,&#10;atendimento)"><bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing></bpmn:callActivity>
<bpmn:endEvent id="ee_obra" name="Chamado: obra"><bpmn:incoming>f10</bpmn:incoming></bpmn:endEvent>
<bpmn:userTask id="t_aloc" name="Alocar responsáveis&#10;pelo atendimento"><bpmn:incoming>f11</bpmn:incoming><bpmn:outgoing>f12</bpmn:outgoing></bpmn:userTask>
<bpmn:userTask id="t_atend" name="Atender&#10;(consultoria ou laudo)"><bpmn:incoming>f12</bpmn:incoming><bpmn:outgoing>f13</bpmn:outgoing></bpmn:userTask>
<bpmn:userTask id="t_nt" name="Registrar orientação /&#10;minuta de Nota Técnica"><bpmn:incoming>f13</bpmn:incoming><bpmn:outgoing>f14</bpmn:outgoing></bpmn:userTask>
<bpmn:endEvent id="ee_res" name="Resolvido"><bpmn:incoming>f14</bpmn:incoming></bpmn:endEvent>
<bpmn:userTask id="t_enc" name="Encaminhar a outro setor&#10;(manutenção, DTI, adm.)"><bpmn:incoming>f15</bpmn:incoming><bpmn:outgoing>f16</bpmn:outgoing></bpmn:userTask>
<bpmn:endEvent id="ee_enc" name="Encaminhado"><bpmn:incoming>f16</bpmn:incoming></bpmn:endEvent>
<bpmn:endEvent id="ee_ne" name="Não enquadrado&#10;(improcedente, duplicado,&#10;cancelado)"><bpmn:incoming>f17</bpmn:incoming></bpmn:endEvent>
<bpmn:sequenceFlow id="f1" sourceRef="se1" targetRef="t_abrir"/>
<bpmn:sequenceFlow id="f2" sourceRef="t_abrir" targetRef="t_triar"/>
<bpmn:sequenceFlow id="f3" sourceRef="t_triar" targetRef="g1"/>
<bpmn:sequenceFlow id="f4" name="sim" sourceRef="g1" targetRef="t_dilig"/>
<bpmn:sequenceFlow id="f5" sourceRef="t_dilig" targetRef="t_resp"/>
<bpmn:sequenceFlow id="f6" sourceRef="t_resp" targetRef="t_triar"/>
<bpmn:sequenceFlow id="f7" name="não" sourceRef="g1" targetRef="g2"/>
<bpmn:sequenceFlow id="f8" name="obra" sourceRef="g2" targetRef="t_conv"/>
<bpmn:sequenceFlow id="f9" sourceRef="t_conv" targetRef="call1"/>
<bpmn:sequenceFlow id="f10" sourceRef="call1" targetRef="ee_obra"/>
<bpmn:sequenceFlow id="f11" name="consultoria / laudo" sourceRef="g2" targetRef="t_aloc"/>
<bpmn:sequenceFlow id="f12" sourceRef="t_aloc" targetRef="t_atend"/>
<bpmn:sequenceFlow id="f13" sourceRef="t_atend" targetRef="t_nt"/>
<bpmn:sequenceFlow id="f14" sourceRef="t_nt" targetRef="ee_res"/>
<bpmn:sequenceFlow id="f15" name="encaminhado" sourceRef="g2" targetRef="t_enc"/>
<bpmn:sequenceFlow id="f16" sourceRef="t_enc" targetRef="ee_enc"/>
<bpmn:sequenceFlow id="f17" name="não enquadrado" sourceRef="g2" targetRef="ee_ne"/>
<bpmn:textAnnotation id="an1"><bpmn:text>O prazo (SLA) é definido pela categoria e pausa enquanto o chamado está em diligência.</bpmn:text></bpmn:textAnnotation>
<bpmn:association id="assoc_an1" sourceRef="g1" targetRef="an1"/>
<bpmn:textAnnotation id="an2"><bpmn:text>Notificações automáticas: autor, responsáveis alocados, disciplina e campus, conforme o evento.</bpmn:text></bpmn:textAnnotation>
<bpmn:association id="assoc_an2" sourceRef="t_triar" targetRef="an2"/>
<bpmn:textAnnotation id="an3"><bpmn:text>Responsáveis contam na carga do profissional (contagem à parte dos pontos do art. 12).</bpmn:text></bpmn:textAnnotation>
<bpmn:association id="assoc_an3" sourceRef="t_aloc" targetRef="an3"/>
</bpmn:process>
