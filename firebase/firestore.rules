rules_version = '2';
// =============================================================================
// SENG Demandas — Security Rules (Cloud Firestore) — v1.1
// Publicar com: npx -y firebase-tools@latest deploy --only firestore:rules
// Modelo: dashboard público lê apenas /demandas e /config; tudo o mais exige
// autenticação; papéis em /usuarios/{uid}.role (gerido só por administrador).
// Papéis: campus | engenharia | chefe | codir | admin (admin pode tudo).
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers -----------------------------------------------------
    function signedIn() { return request.auth != null; }
    function perfil() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data; }
    function role() { return signedIn() ? perfil().role : ''; }
    function ativo() { return signedIn() && perfil().ativo != false; }
    function isAdmin() { return ativo() && role() == 'admin'; }
    function isChefe() { return ativo() && (role() == 'chefe' || role() == 'admin'); }
    function isEng()   { return ativo() && (role() == 'engenharia' || role() == 'chefe' || role() == 'admin'); }
    function isCodir() { return ativo() && (role() == 'codir' || role() == 'admin'); }
    function isInterno() { return isEng() || isCodir(); }
    // Campus pode estar vinculado a vários campi (lista `campi`); compat com o campo único `campus`.
    function isCampusDe(campusId) {
      return ativo() && role() == 'campus'
        && (campusId in perfil().get('campi', []) || perfil().get('campus', '') == campusId);
    }

    function statusValido(s) {
      return s in ['recebido','analise','diligencia','codir','fila','atendimento',
                   'concluido','suspenso','cancelado','nao-enquadrado','excluido'];
    }
    function travada() { return resource.data.status in ['atendimento','concluido']; }
    // .get(campo, null): campos podem estar ausentes — comparação direta com
    // chave ausente lança erro na avaliação das rules e negaria a operação.
    function mantemClassificacao() {
      // Em atendimento/concluído: avaliação, ajuste e aprovação CODIR imutáveis
      return request.resource.data.get('aval', null) == resource.data.get('aval', null)
          && mantemDeliberacao();
    }
    function mantemDeliberacao() {
      // Campos privativos do CODIR não mudam
      return request.resource.data.get('ajuste', null) == resource.data.get('ajuste', null)
          && request.resource.data.get('codirAprovado', null) == resource.data.get('codirAprovado', null);
    }
    function demandaValida(d) {
      return d.objeto is string && d.objeto.size() > 0 && d.objeto.size() <= 120
          && d.descricao is string && d.descricao.size() <= 6000
          && d.campus is string && d.campus.size() <= 8
          && statusValido(d.status)
          && d.especialidades is list && d.especialidades.size() <= 8
          && (!('historico' in d) || (d.historico is list && d.historico.size() <= 400))
          && (!('obsSolicitante' in d) || (d.obsSolicitante is string && d.obsSolicitante.size() <= 4000))
          && (!('obsInterna' in d) || (d.obsInterna is list && d.obsInterna.size() <= 300))
          && (!('obsExterna' in d) || (d.obsExterna is list && d.obsExterna.size() <= 300))
          && (!('comentarios' in d) || (d.comentarios is list && d.comentarios.size() <= 300))
          && (!('anexos' in d) || (d.anexos is list && d.anexos.size() <= 20))
          && (!('etapa' in d) || d.etapa == null || d.etapa in ['projeto','obra'])
          // Workflow v2 (BPMN Atendimento de Chamados v2): fase do atendimento,
          // checklist de artefatos, suspensão estruturada, certame e origem do projeto.
          && (!('fase' in d) || d.fase == null || d.fase in ['planejamento','licitacao','execucao','recebimento'])
          && (!('artefatos' in d) || d.artefatos == null || d.artefatos is map)
          && (!('suspensao' in d) || d.suspensao == null
              || (d.suspensao is map && d.suspensao.get('motivo','') in ['dotacao','tecnico','outro']))
          && (!('certame' in d) || d.certame == null
              || (d.certame is map && d.certame.get('resultado', null) in [null,'exito','deserto','fracassado']))
          && (!('projetoOrigem' in d) || d.projetoOrigem == null || d.projetoOrigem in ['interno','contratado'])
          && (!('chamadoOrigem' in d) || d.chamadoOrigem == null || (d.chamadoOrigem is string && d.chamadoOrigem.size() <= 24));
    }
    // Deliberação do CODIR (gateways "Aprovada?" e "Há dotação orçamentária?"
    // do fluxograma v2). Transições permitidas ao Conselho:
    //   codir → fila       (aprovada, com dotação)
    //   codir → suspenso   (aprovada, SEM dotação — suspensao.motivo = 'dotacao')
    //   codir → analise    (não aprovada — devolvida para reanálise)
    //   codir → cancelado  (não aprovada — encerrada)
    //   fila  → codir      (aprovação desfeita — retirada da fila)
    function somenteDeliberacao() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['codirAprovado','ajuste','status','suspensao','historico','atualizadoEm'])
          && ( request.resource.data.status == resource.data.status
            || ( resource.data.status == 'codir'
                 && ( request.resource.data.status in ['fila','analise','cancelado']
                   || ( request.resource.data.status == 'suspenso'
                        && request.resource.data.get('suspensao', {}).get('motivo','') == 'dotacao' ) ) )
            || (resource.data.status == 'fila' && request.resource.data.status == 'codir') );
    }
    // Edição dos DADOS da solicitação: não altera status, campus, avaliação nem a
    // deliberação do CODIR; permitida apenas até a submissão ao CODIR
    // (status recebido/análise/diligência). Ao entrar em 'codir', congela.
    function editaDados() {
      return resource.data.status in ['recebido','analise','diligencia']
          && request.resource.data.status == resource.data.status
          && request.resource.data.campus == resource.data.campus
          && request.resource.data.get('aval', null) == resource.data.get('aval', null)
          && mantemDeliberacao();
    }

    function chamadoValido(c) {
      return c.assunto is string && c.assunto.size() > 0 && c.assunto.size() <= 140
          && c.descricao is string && c.descricao.size() <= 6000
          && c.campus is string && c.campus.size() <= 8
          && c.categoria is string
          && c.status in ['aberto','triagem','diligencia','atendimento','obra','encaminhado','resolvido','improcedente','duplicado','cancelado']
          && (!('anexos' in c) || (c.anexos is list && c.anexos.size() <= 20))
          && (!('historico' in c) || (c.historico is list && c.historico.size() <= 400))
          && (!('obsInterna' in c) || (c.obsInterna is list && c.obsInterna.size() <= 300))
          && (!('obsExterna' in c) || (c.obsExterna is list && c.obsExterna.size() <= 300))
          && (!('comentarios' in c) || (c.comentarios is list && c.comentarios.size() <= 300));
    }

    // ---------- demandas (fila pública) --------------------------------------
    match /demandas/{id} {
      allow read: if true; // dashboard e relatório públicos

      // Intake unificado nos CHAMADOS: demandas nascem da triagem da SENG
      // (conversão chamado→demanda) — o campus não cria demanda diretamente.
      allow create: if demandaValida(request.resource.data)
        && request.resource.data.status == 'recebido'
        && isEng();

      allow update: if demandaValida(request.resource.data)
        // Trava de atendimento/concluído também bloqueia o soft-delete
        // (arquivo morto): status 'excluido' só fora da trava.
        && !(travada() && request.resource.data.status == 'excluido')
        && (
        // Administrador: tudo, exceto violar a trava
        ( isAdmin() && (!travada() || mantemClassificacao()) )
        // Chefe: gestão e avaliação; deliberação (ajuste/aprovação) é do CODIR
        || ( isChefe() && !isAdmin()
             && mantemDeliberacao()
             && (!travada() || mantemClassificacao()) )
        // Workflow v2 — ciclo projeto → obra: concluída a etapa de projeto, a
        // Chefia devolve a demanda ao CODIR como obra para REPRIORIZAÇÃO —
        // única exceção em que a deliberação (codirAprovado) é zerada e as
        // fases/artefatos/certame do ciclo do projeto são limpos.
        || ( isChefe()
             && resource.data.status == 'atendimento'
             && request.resource.data.status == 'codir'
             && ( resource.data.get('etapa', null) == 'projeto'
               || resource.data.get('tipoDemanda', '') == 'projeto' )
             && request.resource.data.get('etapa', null) == 'obra'
             && request.resource.data.get('codirAprovado', null) == false
             && request.resource.data.get('aval', null) == resource.data.get('aval', null)
             && request.resource.data.get('ajuste', null) == resource.data.get('ajuste', null) )
        // Engenharia: tratamento básico (sem deliberação; respeita a trava).
        // Congelamento de servidor: fora de recebido/análise/diligência, os
        // DADOS da solicitação não podem ser alterados pela Engenharia.
        || ( isEng() && !isChefe()
             && mantemDeliberacao()
             && request.resource.data.status in ['recebido','analise','diligencia','codir']
             && !travada()
             && ( resource.data.status in ['recebido','analise','diligencia']
               || !request.resource.data.diff(resource.data).affectedKeys()
                    .hasAny(['objeto','descricao','local','tipoDemanda','projetoExiste','tombado','valorEstimado','prazoEstimado','processoSuap','especialidades','emergencial']) ) )
        // CODIR: somente aprovação e ajuste, após a análise GUT
        || ( isCodir() && !isAdmin()
             && !travada()
             && resource.data.status in ['codir','fila','suspenso']
             && somenteDeliberacao() )
        // Campus: somente responder diligência da própria unidade
        || ( isCampusDe(resource.data.campus)
             && resource.data.status == 'diligencia'
             && request.resource.data.status in ['diligencia','analise']
             && request.resource.data.get('aval', null) == resource.data.get('aval', null)
             && mantemDeliberacao()
             && request.resource.data.campus == resource.data.campus )
        // Campus (dono): editar somente a observação do solicitante, em qualquer status
        || ( isCampusDe(resource.data.campus)
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsSolicitante','historico','atualizadoEm'])
             && request.resource.data.campus == resource.data.campus )
        // CODIR: editar somente a observação do solicitante/CODIR
        || ( isCodir() && !isAdmin()
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsSolicitante','historico','atualizadoEm']) )
        // Edição dos DADOS até a submissão ao CODIR — perfis internos (Eng/Chefe/CODIR/Admin)
        // e o campus dono. Não toca status, campus, avaliação nem deliberação.
        || ( editaDados() && ( isInterno() || isCampusDe(resource.data.campus) ) )
        // Observações (histórico de comentários, públicas). Só alteram o próprio campo.
        // Interna (Engenharia): Eng/Chefe/Admin. Externa (Solicitante/CODIR): campus dono / CODIR / Admin.
        || ( isEng() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsInterna','historico','atualizadoEm']) )
        || ( (isCampusDe(resource.data.campus) || isCodir()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsExterna','historico','atualizadoEm']) )
        // Linha do tempo unificada: fio único de comentários + anexos — Eng, CODIR e campus dono.
        || ( (isEng() || isCodir() || isCampusDe(resource.data.campus))
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comentarios','anexos','historico','atualizadoEm']) )
        // Workflow v2: durante o atendimento, a equipe técnica (Eng/Chefe/Admin)
        // atualiza fase, checklist de artefatos, certame e origem do projeto —
        // sem tocar status, classificação ou deliberação (imutáveis pela trava).
        || ( isEng()
             && resource.data.status == 'atendimento'
             && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['fase','artefatos','certame','projetoOrigem','historico','atualizadoEm']) )
      );

      // Exclusão: chefe/admin e nunca em atendimento/concluído
      allow delete: if isChefe() && !travada();
    }

    // ---------- dados internos (alocação) — nunca públicos ---------------------
    match /internas/{id} {
      allow read: if isInterno();
      // Chefe/Admin: alocação completa. Engenharia: apenas a observação técnica interna.
      allow write: if isChefe()
        || ( isEng() && (
              ( resource == null && request.resource.data.keys().hasOnly(['obsEngenharia']) )
              || ( resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsEngenharia']) )
            ) );
    }

    // ---------- profissionais — leitura interna, escrita chefe/admin ------------
    match /profissionais/{id} {
      allow read: if isInterno();
      allow write: if isChefe()
        && request.resource.data.nome is string && request.resource.data.nome.size() <= 80
        && (!('email' in request.resource.data) || request.resource.data.email is string);
      // Meu espaço (v1.20): o próprio profissional (vínculo por e-mail) atualiza
      // SOMENTE a foto de perfil e as próprias ausências (controle informativo).
      allow update: if ativo()
        && resource.data.get('email', '') != ''
        && resource.data.get('email', '') == perfil().get('email', '')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fotoUrl', 'ausencias'])
        && (!('ausencias' in request.resource.data) || request.resource.data.ausencias == null
            || (request.resource.data.ausencias is list && request.resource.data.ausencias.size() <= 50));
    }

    // ---------- tarefas da seção (kanban interno — v1.22) ----------------------
    // Trabalho que não é demanda/chamado. Interno à SENG (Eng/Chefe/Admin).
    function tarefaValida(t) {
      return t.titulo is string && t.titulo.size() > 0 && t.titulo.size() <= 140
          && t.situacao in ['aberta', 'andamento', 'concluida', 'cancelada']
          && (!('descricao' in t) || (t.descricao is string && t.descricao.size() <= 2000))
          && (!('responsaveis' in t) || (t.responsaveis is list && t.responsaveis.size() <= 10));
    }
    match /tarefas/{id} {
      allow read: if isEng();
      allow create, update: if isEng() && tarefaValida(request.resource.data);
      allow delete: if isChefe();
    }

    // ---------- usuários — leitura p/ chefia (vínculo de profissionais);
    //            gestão pelo admin; sempre ao menos um admin --------------------
    match /usuarios/{uid} {
      allow read: if isChefe() || (signedIn() && request.auth.uid == uid);
      allow create: if isAdmin()
        && request.resource.data.role in ['campus','engenharia','chefe','codir','admin']
        && request.resource.data.nome is string && request.resource.data.nome.size() <= 80;
      allow update: if isAdmin()
        && request.resource.data.role in ['campus','engenharia','chefe','codir','admin']
        && request.resource.data.nome is string && request.resource.data.nome.size() <= 80
        // Revogação/desativação de administrador: só por OUTRO administrador
        // (garante que sempre reste ao menos um — o revogador).
        && ( resource.data.role != 'admin'
          || (request.resource.data.role == 'admin' && request.resource.data.ativo != false)
          || request.auth.uid != uid );
      allow delete: if isAdmin() && resource.data.role != 'admin';
    }

    // ---------- log de auditoria — gravação por autenticados, leitura só admin ---
    match /logs/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && ativo()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.acao is string && request.resource.data.acao.size() <= 120
        && request.resource.data.alvo is string && request.resource.data.alvo.size() <= 160
        && request.resource.data.detalhes is string && request.resource.data.detalhes.size() <= 1000
        && request.resource.data.ts is number;
      allow update, delete: if false; // imutável (append-only)
    }

    // ---------- parâmetros — leitura pública (cálculo no cliente) ----------------
    match /config/{doc} {
      allow read: if true;
      allow write: if isChefe();
    }

    // ---------- diretório de roteamento de notificações (SEM nomes) -------------
    // Entradas: uid, papel, ativo e — para profissionais ativos — pid e disciplina.
    // Lido por qualquer autenticado (necessário até ao Campus para endereçar os
    // avisos da disciplina); gravado só por chefe/admin (auto-sincronizado a
    // partir de /usuarios e /profissionais). Não contém nomes nem e-mails.
    match /diretorio/{doc} {
      allow read: if signedIn();
      allow write: if isChefe();
    }

    // ---------- notificações (inbox pessoal) ------------------------------------
    // Cada documento pertence a um destinatário (campo `para` = uid). Leitura só
    // do próprio; criação por qualquer autenticado (fan-out client-side, com o
    // autor carimbado em `de`); o destinatário só pode alternar `lida`.
    match /notificacoes/{id} {
      allow read: if signedIn() && resource.data.para == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.de == request.auth.uid
        && request.resource.data.para is string
        && request.resource.data.tipo is string
        && request.resource.data.demandaId is string
        && request.resource.data.texto is string && request.resource.data.texto.size() <= 300
        && request.resource.data.lida == false
        && request.resource.data.criadoEm is number;
      allow update: if signedIn() && resource.data.para == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida'])
        && request.resource.data.lida is bool;
      allow delete: if signedIn() && resource.data.para == request.auth.uid;
    }

    // ---------- chamados (intake da SENG) — ADR-002 -----------------------------
    // Não é público: leem a SENG (interno) e o campus dono. Escrita direto ou pela
    // camada de API (sob o token do usuário) — as rules valem igual.
    match /chamados/{id} {
      allow read: if isInterno() || (resource != null && isCampusDe(resource.data.campus));
      allow create: if chamadoValido(request.resource.data)
        && request.resource.data.status == 'aberto'
        && ( isEng() || isCampusDe(request.resource.data.campus) );
      allow update: if chamadoValido(request.resource.data)
        && request.resource.data.campus == resource.data.campus
        && (
          // SENG/Admin: triagem, resolução e status
          isEng()
          // Campus dono: complementar/responder diligência, comentar (externa) e anexar.
          // prazoLimite/diligenciaDesde: recomposição do SLA pausado ao responder a
          // diligência (workflow v2) — o prazo só pode ser estendido, nunca reduzido.
          || ( isCampusDe(resource.data.campus)
               && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['descricao','status','obsExterna','comentarios','anexos','historico','atualizadoEm','prazoLimite','diligenciaDesde'])
               && request.resource.data.get('prazoLimite', 0) >= resource.data.get('prazoLimite', 0)
               && request.resource.data.status in ['aberto','triagem','diligencia'] )
          // Campus dono: comentar também com o chamado EM ATENDIMENTO
          // (consultoria/laudo em curso) — sem mudar status nem outros campos.
          || ( isCampusDe(resource.data.campus)
               && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['obsExterna','comentarios','historico','atualizadoEm'])
               && request.resource.data.status == resource.data.status )
        );
      allow delete: if isChefe();
    }
  }
}
