rules_version = '2';
// =============================================================================
// SENG Demandas — Security Rules (Cloud Storage) — anexos de chamados
// Publicar: npx -y firebase-tools@latest deploy --only storage --project cpii-seng
// Espelha a autorização dos chamados no Firestore: leem/gravam a SENG (interno)
// e o campus dono. O papel vem de /usuarios/{uid} via firestore.get.
// =============================================================================
service firebase.storage {
  match /b/{bucket}/o {

    // ---- helpers (papel a partir do Firestore, sob o token do usuário) ------
    function perfil() {
      return firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data;
    }
    function role()  { return request.auth != null ? perfil().role : ''; }
    function ativo() { return request.auth != null && perfil().get('ativo', true) != false; }
    function isInterno() { return ativo() && role() in ['engenharia', 'chefe', 'admin', 'codir']; }
    // Campus pode estar vinculado a vários campi (lista `campi`); compat com `campus`.
    function isCampusDe(campusId) {
      return ativo() && role() == 'campus'
        && (campusId in perfil().get('campi', []) || perfil().get('campus', '') == campusId);
    }
    // Só imagens comuns e PDF; até 10 MB por arquivo.
    function tipoOk() {
      return request.resource.contentType.matches('image/(jpeg|png|webp|heic|heif)')
          || request.resource.contentType == 'application/pdf';
    }

    // ---- anexos de chamados: chamados/{campus}/{chamadoId}/{arquivo} ---------
    match /chamados/{campus}/{chamadoId}/{arquivo} {
      allow read:   if isInterno() || isCampusDe(campus);
      allow write:  if (isInterno() || isCampusDe(campus))
                    && request.resource.size < 10 * 1024 * 1024
                    && tipoOk();
      allow delete: if isInterno() || isCampusDe(campus);
    }

    // Tudo o mais: negado por padrão.
    match /{allPaths=**} { allow read, write: if false; }
  }
}
